# CargoBridge AI — Environment Variables
# Copy this file to .env and fill in your values

# Flask
SECRET_KEY=your-long-random-secret-key-change-this-in-production
FLASK_ENV=development

# Database
# Development (SQLite — default, no config needed)
DATABASE_URL=sqlite:///cargobridge.db
# Production (PostgreSQL — uncomment and set)
# DATABASE_URL=postgresql://user:password@host:5432/cargobridge

# Twilio (WhatsApp + Voice)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Public base URL (used for WhatsApp media attachments)
# Local dev: use ngrok URL
# Production: your deployed URL
BASE_URL=https://your-ngrok-url.ngrok-free.app

# AIS vessel data (MarineTraffic or AISHub — leave blank to use mock data)
AIS_API_KEY=

# ── CrewAI Multi-Agent Pipeline (optional) ─────────────────────────────────
# Set OPENAI_API_KEY to activate the 3-agent CrewAI scoring pipeline.
# Without it the app falls back to the built-in deterministic expert system.
OPENAI_API_KEY=sk-...

# Optional: Serper.dev web search for the Weather/AIS Validator agent
# Get a free key at https://serper.dev
SERPER_API_KEY=
